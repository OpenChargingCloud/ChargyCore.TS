{
  "name": "@open-charging-cloud/chargy-core",
  "version": "0.2.0",
  "description": "Shared Chargy TypeScript core for Chargy desktop, web, and mobile applications.",
  "type": "module",
  "license": "AGPL-3.0-only",
  "author": "GraphDefined GmbH",
  "homepage": "https://github.com/OpenChargingCloud",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenChargingCloud/ChargyCore.TS.git"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "i18n.json",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./i18n.json": "./i18n.json",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && npm run build:js && npm run build:types",
    "build:js": "tsup",
    "build:types": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run lint && npm test && npm run build",
    "prepare": "npm run build"
  },
  "dependencies": {
    "asn1.js": "^5.4.1",
    "base32-decode": "^1.0.0",
    "buffer": "^6.0.3",
    "decimal.js": "^10.6.0",
    "elliptic": "^6.6.1",
    "file-type": "^22.0.1",
    "jsqr": "^1.4.0",
    "moment": "^2.30.1",
    "pdfjs-dist": "^6.0.227",
    "seek-bzip": "^2.0.0"
  },
  "optionalDependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "jpeg-js": "^0.4.4",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@oozcitak/dom": "1.15.10",
    "@eslint/js": "^9.39.2",
    "@types/elliptic": "^6.4.18",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.49.0",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "typescript": ">=5.4"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
